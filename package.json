{
  "name": "kora-football",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "dev:3012": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3012",
    "build": "next build",
    "build:start": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build && next start",
    "start": "next start",
    "start:3012": "next start -p 3012",
    "start:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build && next start",
    "start:clean:3012": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build && next start -p 3012",
    "lint": "next lint",
    "test:e2e": "node scripts/e2e-test.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.1",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "next-intl": "^3.26.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5"
  }
}
